<% content_for :title, "Dashboard — ttime.ai" %>

<div class="space-y-6">
  <!-- Header with Filters -->
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-white">Dashboard</h1>
      <p class="text-gray-400 text-sm mt-1">
        <%= @date_range == "today" ? "Today's" : @date_range.humanize %>
        agent activity overview
      </p>
    </div>
    <div class="text-sm text-gray-400">
      <%= @start_date.strftime("%b %-d") %> — <%= @end_date.strftime("%b %-d, %Y") %>
    </div>
  </div>

  <!-- Filter Bar -->
  <div class="bg-gray-900 rounded-xl border border-gray-800 p-4">
    <%= form_with url: dashboard_path, method: :get, class: "flex flex-wrap gap-3 items-end", data: { turbo: false } do |f| %>
      <div class="flex flex-col gap-1">
        <%= f.label :date_range, "Date Range", class: "text-xs text-gray-500 uppercase" %>
        <%= f.select :date_range,
            options_for_select([
              ["Today", "today"],
              ["Yesterday", "yesterday"],
              ["Last 7 Days", "last_7_days"],
              ["Last 30 Days", "last_30_days"]
            ], @date_range),
            {},
            class: "bg-gray-800 border border-gray-700 text-white text-sm rounded-lg px-3 py-2 focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
      </div>

      <div class="flex flex-col gap-1">
        <%= f.label :project_id, "Project", class: "text-xs text-gray-500 uppercase" %>
        <%= f.select :project_id,
            options_for_select([["All Projects", ""]] + @available_projects, @selected_project),
            {},
            class: "bg-gray-800 border border-gray-700 text-white text-sm rounded-lg px-3 py-2 focus:ring-2 focus:ring-indigo-500 focus:border-transparent min-w-[140px]" %>
      </div>

      <div class="flex flex-col gap-1">
        <%= f.label :agent_type, "Agent", class: "text-xs text-gray-500 uppercase" %>
        <%= f.select :agent_type,
            options_for_select([["All Agents", ""]] + HeartbeatEvent::AGENT_TYPES.map { |a| [a.humanize, a] }, @selected_agent),
            {},
            class: "bg-gray-800 border border-gray-700 text-white text-sm rounded-lg px-3 py-2 focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
      </div>

      <div class="flex flex-col gap-1">
        <%= f.label :language, "Language", class: "text-xs text-gray-500 uppercase" %>
        <%= f.select :language,
            options_for_select([["All Languages", ""]] + @available_languages, @selected_language),
            {},
            class: "bg-gray-800 border border-gray-700 text-white text-sm rounded-lg px-3 py-2 focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
      </div>

      <%= f.submit "Apply", class: "bg-indigo-600 hover:bg-indigo-500 text-white text-sm px-4 py-2 rounded-lg transition-colors" %>

      <% if @selected_project.present? || @selected_agent.present? || @selected_language.present? %>
        <%= link_to "Clear", dashboard_path(date_range: @date_range), class: "text-gray-400 hover:text-white text-sm px-3 py-2" %>
      <% end %>
    <% end %>
  </div>

  <!-- Stats Cards - Primary Row -->
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5">
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-indigo-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Coding Time</p>
          <p class="text-xl font-bold text-white mt-0.5"><%= format_duration(@stats[:coding_time]) %></p>
        </div>
      </div>
    </div>

    <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10m-11 9h12a2 2 0 002-2V7a2 2 0 00-2-2H6a2 2 0 00-2 2v11a2 2 0 002 2z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Session Time</p>
          <p class="text-xl font-bold text-white mt-0.5"><%= format_duration(@stats[:session_time]) %></p>
        </div>
      </div>
    </div>

    <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-emerald-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Agent Time</p>
          <p class="text-xl font-bold text-white mt-0.5"><%= format_duration(@stats[:agent_time]) %></p>
        </div>
      </div>
    </div>

    <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-pink-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Human Time</p>
          <p class="text-xl font-bold text-white mt-0.5"><%= format_duration(@stats[:human_time]) %></p>
        </div>
      </div>
    </div>

    <div class="bg-gray-900 rounded-xl border border-gray-800 p-5">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-yellow-500/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Tokens Used</p>
          <p class="text-xl font-bold text-white mt-0.5"><%= number_with_delimiter(@stats[:total_tokens]) %></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Secondary Metrics Row -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-gray-900/50 rounded-lg border border-gray-800 p-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Total Events</p>
      <p class="text-2xl font-bold text-white"><%= number_with_delimiter(@stats[:total_events]) %></p>
    </div>

    <div class="bg-gray-900/50 rounded-lg border border-gray-800 p-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Active Projects</p>
      <p class="text-2xl font-bold text-white"><%= @stats[:active_projects] %></p>
    </div>

    <div class="bg-gray-900/50 rounded-lg border border-gray-800 p-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Productivity Ratio</p>
      <p class="text-2xl font-bold text-white"><%= @stats[:productivity_ratio] %>%</p>
      <p class="text-xs text-gray-600 mt-1">agent vs human time</p>
    </div>

    <div class="bg-gray-900/50 rounded-lg border border-gray-800 p-4">
      <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Avg Session</p>
      <p class="text-2xl font-bold text-white"><%= format_duration(@stats[:avg_session_length]) %></p>
    </div>
  </div>

  <!-- Highlights Row -->
  <% if @top_project || @peak_hour %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <% if @top_project %>
    <div class="bg-gradient-to-r from-indigo-900/40 to-purple-900/40 rounded-lg border border-indigo-800/50 p-4">
      <p class="text-xs text-indigo-400 uppercase tracking-wide mb-1">Most Active Project</p>
      <p class="text-lg font-semibold text-white"><%= @top_project[0] %></p>
      <p class="text-xs text-gray-500 mt-1"><%= @top_project[1] %> events</p>
    </div>
    <% end %>

    <% if @peak_hour %>
    <div class="bg-gradient-to-r from-emerald-900/40 to-teal-900/40 rounded-lg border border-emerald-800/50 p-4">
      <p class="text-xs text-emerald-400 uppercase tracking-wide mb-1">Peak Coding Hour</p>
      <p class="text-lg font-semibold text-white"><%= format("%02d:00", @peak_hour) %> — <%= format("%02d:00", (@peak_hour + 1) % 24) %></p>
      <p class="text-xs text-gray-500 mt-1">most active time of day</p>
    </div>
    <% end %>
  </div>
  <% end %>

  <!-- Activity Chart -->
  <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
    <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wide mb-4">Activity Timeline</h2>
    <div class="flex items-end gap-2 h-32" data-controller="activity-chart" data-activity-chart-data-value="<%= @daily_activity.to_json.html_safe %>">
      <% @daily_activity.each do |day| %>
        <%
          max_seconds = @daily_activity.map { |d| d[:seconds] }.max
          pct = max_seconds && max_seconds > 0 ? ((day[:seconds].to_f / max_seconds) * 100).round : 0
          height = [pct, 4].max
        %>
        <div class="flex flex-col items-center gap-1 flex-1">
          <span class="text-xs text-gray-500"><%= format_duration(day[:seconds]) %></span>
          <div class="w-full bg-indigo-500 rounded-t hover:bg-indigo-400 transition-colors cursor-pointer relative group" style="height: <%= height %>%;">
            <div class="absolute bottom-full mb-2 left-1/2 -translate-x-1/2 bg-gray-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 whitespace-nowrap pointer-events-none">
              <%= day[:label] %>: <%= format_duration(day[:seconds]) %>
            </div>
          </div>
          <span class="text-xs text-gray-500"><%= day[:label] %></span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Session Timing & Token Usage -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
      <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wide mb-4">Agent vs Human Time</h2>
      <div class="space-y-3">
        <% @daily_session_timing.each do |day| %>
          <% total = [day[:session_seconds], 1].max %>
          <% agent_pct = ((day[:agent_seconds].to_f / total) * 100).round %>
          <% human_pct = ((day[:human_seconds].to_f / total) * 100).round %>
          <div>
            <div class="flex items-center justify-between text-xs text-gray-500 mb-1">
              <span><%= day[:label] %></span>
              <span class="text-gray-400">
                <span class="text-emerald-400"><%= format_duration(day[:agent_seconds]) %></span>
                /
                <span class="text-pink-400"><%= format_duration(day[:human_seconds]) %></span>
              </span>
            </div>
            <div class="flex h-2 overflow-hidden rounded-full bg-gray-800">
              <div class="bg-emerald-500" style="width: <%= agent_pct %>%;" title="Agent: <%= format_duration(day[:agent_seconds]) %>"></div>
              <div class="bg-pink-500" style="width: <%= human_pct %>%;" title="Human: <%= format_duration(day[:human_seconds]) %>"></div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="flex gap-4 mt-4 text-xs">
        <span class="flex items-center gap-1 text-gray-400"><span class="w-2 h-2 rounded-full bg-emerald-500"></span> Agent</span>
        <span class="flex items-center gap-1 text-gray-400"><span class="w-2 h-2 rounded-full bg-pink-500"></span> Human</span>
      </div>
    </div>

    <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
      <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wide mb-4">Token Usage Trend</h2>
      <div class="flex items-end gap-2 h-32">
        <% max_tokens = @tokens_by_day.map { |d| d[:tokens] }.max %>
        <% @tokens_by_day.each do |day| %>
          <%
            pct = max_tokens && max_tokens > 0 ? ((day[:tokens].to_f / max_tokens) * 100).round : 0
            height = [pct, 4].max
          %>
          <div class="flex flex-col items-center gap-1 flex-1">
            <span class="text-xs text-gray-500"><%= day[:tokens] > 0 ? number_to_human(day[:tokens], units: { thousand: "k" }) : "0" %></span>
            <div class="w-full bg-yellow-500 rounded-t hover:bg-yellow-400 transition-colors cursor-pointer" style="height: <%= height %>%;" title="<%= day[:date] %>: <%= number_with_delimiter(day[:tokens]) %> tokens"></div>
            <span class="text-xs text-gray-500"><%= day[:date] %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Hourly Activity Heatmap -->
  <% if @hourly_activity.any? { |h| h[:count] > 0 } %>
  <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
    <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wide mb-4">Hourly Activity</h2>
    <div class="grid grid-cols-12 gap-1">
      <% @hourly_activity.each do |hour| %>
        <% intensity = @hourly_activity.map { |h| h[:count] }.max > 0 ? (hour[:count].to_f / @hourly_activity.map { |h| h[:count] }.max) : 0 %>
        <% bg_class = case intensity
           when 0 then "bg-gray-800"
           when 0...0.25 then "bg-indigo-900/40"
           when 0.25...0.5 then "bg-indigo-800/60"
           when 0.5...0.75 then "bg-indigo-600/80"
           else "bg-indigo-500"
           end %>
        <div class="<%= bg_class %> rounded p-2 text-center" title="<%= hour[:hour] %>: <%= hour[:count] %> events">
          <span class="text-xs text-gray-400"><%= hour[:hour] %></span>
          <span class="block text-xs font-medium text-white mt-1"><%= hour[:count] %></span>
        </div>
      <% end %>
    </div>
  </div>
  <% end %>

  <!-- Breakdowns -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Language Breakdown -->
    <% if @language_breakdown.any? %>
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
      <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wide mb-4">Languages</h2>
      <div class="space-y-3">
        <% total = @language_breakdown.sum { |_, c| c } %>
        <% @language_breakdown.each do |lang, count| %>
          <div class="flex items-center gap-3">
            <div class="w-24 text-sm text-gray-300 truncate"><%= lang %></div>
            <div class="flex-1 bg-gray-800 rounded-full h-2">
              <div class="bg-indigo-500 h-2 rounded-full" style="width: <%= ((count.to_f / total) * 100).round %>%"></div>
            </div>
            <div class="text-xs text-gray-500 w-8 text-right"><%= count %></div>
          </div>
        <% end %>
      </div>
    </div>
    <% end %>

    <!-- Agent Breakdown -->
    <% if @agent_breakdown.any? %>
    <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
      <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wide mb-4">Agents</h2>
      <div class="space-y-3">
        <% total = @agent_breakdown.sum { |_, c| c } %>
        <% @agent_breakdown.each do |agent, count| %>
          <div class="flex items-center gap-3">
            <div class="w-28 text-sm text-gray-300 truncate capitalize"><%= agent.to_s.humanize %></div>
            <div class="flex-1 bg-gray-800 rounded-full h-2">
              <div class="bg-purple-500 h-2 rounded-full" style="width: <%= ((count.to_f / total) * 100).round %>%"></div>
            </div>
            <div class="text-xs text-gray-500 w-8 text-right"><%= count %></div>
          </div>
        <% end %>
      </div>
    </div>
    <% end %>
  </div>

  <!-- Recent Activity -->
  <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wide">Recent Activity</h2>
      <span class="text-xs text-gray-500">Last 50 events</span>
    </div>

    <% if @recent_heartbeats.empty? %>
      <div class="text-center py-12 text-gray-600">
        <p class="text-lg">No activity found.</p>
        <p class="text-sm mt-2">
          <% if @selected_project.present? || @selected_agent.present? || @selected_language.present? %>
            Try adjusting your filters to see more results.
          <% else %>
            Start sending heartbeats from your agent integration to see activity here.
          <% end %>
        </p>
        <% if @selected_project.blank? && @selected_agent.blank? && @selected_language.blank? %>
          <div class="mt-4">
            <%= link_to "Get API Key", api_keys_path, class: "text-indigo-400 hover:text-indigo-300 text-sm" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-gray-500 border-b border-gray-800">
              <th class="pb-2 font-medium">Entity</th>
              <th class="pb-2 font-medium">Language</th>
              <th class="pb-2 font-medium">Agent</th>
              <th class="pb-2 font-medium">Project</th>
              <th class="pb-2 font-medium">Agent/Human</th>
              <th class="pb-2 font-medium text-right">Time</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <% @recent_heartbeats.each do |hb| %>
              <tr class="text-gray-300 hover:bg-gray-800/50 transition-colors">
                <td class="py-2 font-mono text-xs text-gray-400 max-w-xs truncate"><%= hb.entity %></td>
                <td class="py-2"><span class="px-2 py-0.5 bg-gray-800 rounded text-xs"><%= hb.language || "—" %></span></td>
                <td class="py-2 capitalize"><%= hb.agent_type.humanize %></td>
                <td class="py-2 text-indigo-400"><%= hb.project&.name || "—" %></td>
                <td class="py-2 text-xs text-gray-500">
                  <% if hb.agent_active_seconds.present? || hb.human_active_seconds.present? %>
                    <span class="text-emerald-400"><%= format_duration(hb.agent_active_seconds.to_i) %></span>
                    /
                    <span class="text-pink-400"><%= format_duration(hb.human_active_seconds.to_i) %></span>
                  <% else %>
                    —
                  <% end %>
                </td>
                <td class="py-2 text-gray-500 text-right text-xs"><%= time_ago_in_words(hb.timestamp) %> ago</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>

  <!-- Quick Start -->
  <% if @stats[:total_events] == 0 && current_user.api_keys.active.empty? %>
  <div class="bg-indigo-900/30 border border-indigo-700 rounded-xl p-6">
    <h2 class="text-lg font-semibold text-white mb-2">Get started with ttime.ai</h2>
    <p class="text-gray-300 text-sm mb-4">Connect your AI coding agent to start tracking sessions, tokens, languages, and more.</p>
    <div class="flex gap-3">
      <%= link_to "Create API Key", api_keys_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white text-sm px-4 py-2 rounded-lg transition-colors" %>
    </div>
  </div>
  <% end %>
</div>
