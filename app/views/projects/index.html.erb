<% content_for :title, "Projects — ttime.ai" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold text-white">Projects</h1>
      <p class="text-gray-400 text-sm mt-1">Track your agent activity by project</p>
    </div>
    <%= link_to "New Project", new_project_path,
        class: "bg-indigo-600 hover:bg-indigo-500 text-white text-sm px-4 py-2 rounded-lg transition-colors" %>
  </div>

  <% if @projects.empty? %>
    <div class="bg-gray-900 rounded-xl border border-gray-800 text-center py-16 text-gray-600">
      <p class="text-lg">No projects yet.</p>
      <p class="text-sm mt-2">Projects are automatically created when you send heartbeats with a project name.</p>
    </div>
  <% else %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @projects.each do |project| %>
        <%= link_to project_path(project), class: "bg-gray-900 rounded-xl border border-gray-800 p-5 hover:border-gray-700 transition-colors block" do %>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-4 h-4 rounded-full flex-shrink-0" style="background-color: <%= project.color %>"></div>
            <h3 class="text-white font-medium truncate"><%= project.name %></h3>
          </div>
          <% if project.description.present? %>
            <p class="text-gray-500 text-sm truncate"><%= project.description %></p>
          <% end %>
          <p class="text-gray-600 text-xs mt-3">Created <%= time_ago_in_words(project.created_at) %> ago</p>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
