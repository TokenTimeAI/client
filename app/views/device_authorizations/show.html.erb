<div class="max-w-2xl mx-auto py-12 px-4">
  <h1 class="text-2xl font-semibold text-gray-900">Approve local heartbeat daemon</h1>

  <div class="mt-6 rounded-lg border border-gray-200 bg-white p-6 shadow-sm space-y-4">
    <div>
      <p class="text-sm text-gray-500">Machine</p>
      <p class="text-base font-medium text-gray-900"><%= @device_authorization.machine_name.presence || "Unknown machine" %></p>
    </div>

    <div>
      <p class="text-sm text-gray-500">User code</p>
      <p class="text-base font-mono font-medium text-gray-900"><%= @device_authorization.user_code %></p>
    </div>

    <div>
      <p class="text-sm text-gray-500">Expires at</p>
      <p class="text-base text-gray-900"><%= @device_authorization.expires_at.in_time_zone(current_user.timezone || "UTC").strftime("%Y-%m-%d %H:%M:%S %Z") %></p>
    </div>

    <% if @device_authorization.pending? && !@device_authorization.expired? %>
      <p class="text-sm text-gray-600">
        Approving this request will create a new API key for your local heartbeat daemon.
      </p>

      <%= button_to "Approve daemon", approve_device_authorization_path(@device_authorization.user_code), method: :post, class: "inline-flex items-center rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700" %>
    <% elsif @device_authorization.approved? %>
      <p class="rounded-md bg-green-50 p-3 text-sm text-green-800">
        Approved. Return to the daemon; it can complete the bootstrap flow now.
      </p>
    <% elsif @device_authorization.claimed? %>
      <p class="rounded-md bg-blue-50 p-3 text-sm text-blue-800">
        This device authorization has already been claimed.
      </p>
    <% else %>
      <p class="rounded-md bg-red-50 p-3 text-sm text-red-800">
        This device authorization has expired. Start the bootstrap flow again from your daemon.
      </p>
    <% end %>
  </div>
</div>
