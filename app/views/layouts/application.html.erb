<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "ttime.ai — Agent Activity Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="ttime.ai">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.svg">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" unless Rails.env.test? %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-950 text-gray-100 min-h-screen" data-controller="app">
    <% if user_signed_in? %>
      <nav class="bg-gray-900 border-b border-gray-800 px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <%= link_to root_path, class: "flex items-center gap-2" do %>
            <%= image_tag "logo-main.svg", alt: "TokenTime.ai", class: "h-8 w-auto" %>
          <% end %>
          <div class="flex items-center gap-4 text-sm">
            <%= link_to "Dashboard", dashboard_path, class: "text-gray-300 hover:text-white transition-colors #{current_page?(dashboard_path) ? 'text-white font-medium' : ''}" %>
            <%= link_to "Projects", projects_path, class: "text-gray-300 hover:text-white transition-colors" %>
            <%= link_to "API Keys", api_keys_path, class: "text-gray-300 hover:text-white transition-colors" %>
            <%= link_to "Billing", billing_path, class: "text-gray-300 hover:text-white transition-colors #{current_page?(billing_path) ? 'text-white font-medium' : ''}" %>
          </div>
        </div>
        <div class="flex items-center gap-4 text-sm">
          <span class="text-gray-400"><%= current_user.display_name %></span>
          <% if current_user.subscription_active? %>
            <span class="rounded-full border border-green-700/60 bg-green-900/20 px-2.5 py-1 text-xs font-medium text-green-200">Personal plan active</span>
          <% end %>
          <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete },
              class: "text-gray-400 hover:text-white transition-colors" %>
        </div>
      </nav>
    <% else %>
      <nav class="bg-gray-900/50 border-b border-gray-800/50 px-6 py-4 flex items-center justify-between">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <%= image_tag "logo-main.svg", alt: "TokenTime.ai", class: "h-8 w-auto" %>
        <% end %>
        <div class="flex items-center gap-4">
          <%= link_to "Sign in", new_user_session_path, class: "text-gray-300 hover:text-white transition-colors text-sm" %>
          <%= link_to "Get Started", new_user_registration_path, class: "bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
        </div>
      </nav>
    <% end %>

    <main class="<%= user_signed_in? ? 'container mx-auto px-6 py-8 max-w-7xl' : '' %>">
      <% if notice %>
        <div class="mb-6 bg-green-900/40 border border-green-700 text-green-300 px-4 py-3 rounded-lg" role="alert">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-6 bg-red-900/40 border border-red-700 text-red-300 px-4 py-3 rounded-lg" role="alert">
          <%= alert %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
