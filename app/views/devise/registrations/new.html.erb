<div class="min-h-screen flex items-center justify-center bg-gray-950">
  <div class="w-full max-w-md px-6">
    <div class="text-center mb-8">
      <a href="/" class="text-indigo-400 font-bold text-3xl">ttime.ai</a>
      <p class="text-gray-500 text-sm mt-2">Start tracking your AI coding agent activity</p>
    </div>

    <div class="bg-gray-900 rounded-2xl border border-gray-800 p-8">
      <h2 class="text-xl font-semibold text-white mb-6">Create your account</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <% resource.errors.full_messages.each do |msg| %>
          <div class="text-red-400 text-sm bg-red-900/20 border border-red-800 rounded-lg px-4 py-2"><%= msg %></div>
        <% end %>

        <div>
          <%= f.label :name, "Full Name", class: "block text-sm font-medium text-gray-400 mb-2" %>
          <%= f.text_field :name, autofocus: true,
              class: "w-full bg-gray-950 border border-gray-700 text-white placeholder-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
              placeholder: "Jane Smith" %>
        </div>

        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-400 mb-2" %>
          <%= f.email_field :email, autocomplete: "email",
              class: "w-full bg-gray-950 border border-gray-700 text-white placeholder-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent",
              placeholder: "you@example.com" %>
        </div>

        <div>
          <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-400 mb-2" %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "w-full bg-gray-950 border border-gray-700 text-white placeholder-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
          <% if @minimum_password_length %>
            <p class="text-xs text-gray-600 mt-1">Minimum <%= @minimum_password_length %> characters</p>
          <% end %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-gray-400 mb-2" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full bg-gray-950 border border-gray-700 text-white placeholder-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <%= f.submit "Create account",
            class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2.5 rounded-lg transition-colors cursor-pointer" %>
      <% end %>

      <p class="text-center text-sm text-gray-500 mt-6">
        Already have an account?
        <%= link_to "Sign in", new_session_path(resource_name), class: "text-indigo-400 hover:text-indigo-300" %>
      </p>
    </div>
  </div>
</div>
