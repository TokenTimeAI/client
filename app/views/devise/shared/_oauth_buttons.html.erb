<div class="space-y-3">
  <% providers.each do |provider| %>
    <% provider_label = provider == :github ? "GitHub" : "Google" %>
    <%= button_to omniauth_authorize_path(resource_name, provider),
        method: :post,
        data: { turbo: false },
        class: "w-full inline-flex items-center justify-center gap-3 rounded-lg border border-gray-700 bg-gray-950 px-4 py-2.5 text-sm font-medium text-white hover:border-gray-500 hover:bg-gray-900 transition-colors cursor-pointer" do %>
      <span class="text-base"><%= provider == :github ? "⌘" : "G" %></span>
      <span>Continue with <%= provider_label %></span>
    <% end %>
  <% end %>
</div>
