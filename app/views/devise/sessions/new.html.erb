<div class="min-h-screen flex items-center justify-center bg-gray-950">
  <div class="w-full max-w-md px-6">
    <!-- Logo -->
    <div class="text-center mb-8">
      <a href="/" class="text-indigo-400 font-bold text-3xl">ttime.ai</a>
      <p class="text-gray-500 text-sm mt-2">Agent activity tracking for AI coding tools</p>
    </div>

    <div class="bg-gray-900 rounded-2xl border border-gray-800 p-8">
      <h2 class="text-xl font-semibold text-white mb-6">Sign in to your account</h2>

      <% oauth_providers = resource_class.omniauth_providers.select { |provider| Devise.omniauth_configs.key?(provider) } %>
      <% if oauth_providers.any? %>
        <%= render "devise/shared/oauth_buttons", resource_name: resource_name, providers: oauth_providers %>

        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-gray-800"></div>
          </div>
          <div class="relative flex justify-center text-xs uppercase tracking-[0.3em] text-gray-600">
            <span class="bg-gray-900 px-3">or continue with email</span>
          </div>
        </div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <div>
          <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-400 mb-2" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full bg-gray-950 border border-gray-700 text-white placeholder-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <div>
          <%= f.label :password, "Password", class: "block text-sm font-medium text-gray-400 mb-2" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full bg-gray-950 border border-gray-700 text-white placeholder-gray-600 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "rounded border-gray-700 bg-gray-950 text-indigo-500 focus:ring-indigo-500" %>
            <%= f.label :remember_me, "Remember me", class: "text-sm text-gray-400" %>
          </div>
        <% end %>

        <%= f.submit "Sign in",
            class: "w-full bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2.5 rounded-lg transition-colors cursor-pointer" %>
      <% end %>

      <p class="text-center text-sm text-gray-500 mt-6">
        Don't have an account?
        <%= link_to "Sign up", new_registration_path(resource_name), class: "text-indigo-400 hover:text-indigo-300" %>
      </p>
      <p class="text-center text-sm text-gray-500 mt-2">
        <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-indigo-400 hover:text-indigo-300" %>
      </p>
    </div>
  </div>
</div>
